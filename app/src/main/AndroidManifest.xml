<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        PERMISOS DECLARADOS — solo lo estrictamente necesario:
        • READ_MEDIA_AUDIO   → leer música (Android 13+, API 33+)
        • READ_EXTERNAL_STORAGE → leer música (Android < 13)
        • FOREGROUND_SERVICE → notificación persistente mientras suena
        • FOREGROUND_SERVICE_MEDIA_PLAYBACK → tipo de servicio (API 34+)
        • WAKE_LOCK → mantener CPU activa si la pantalla se apaga

        NO HAY INTERNET. Sin ese permiso declarado aquí, Android
        bloquea cualquier conexión de red a nivel de sistema, sin
        importar qué código esté en la app. Es imposible filtrar datos.
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_launcher_fg"
        android:roundIcon="@drawable/ic_launcher_fg"
        android:label="@string/app_name"
        android:theme="@style/Theme.LocalPlay"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            MusicService: servicio en foreground tipo MEDIA_PLAYBACK.
            Media3 genera la notificación de controles automáticamente.
        -->
        <service
            android:name=".MusicService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

    </application>
</manifest>
