<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ── Barra superior ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▶ LocalPlay"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"/>

        <TextView
            android:id="@+id/textTrackCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="— canciones"
            android:textColor="@color/text_muted"
            android:textSize="12sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/badge_secure"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="🔒 sin red"
            android:textColor="#50dc8c"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- ── Sección del reproductor (altura fija) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp"
        android:gravity="center_horizontal">

        <!-- Carátula -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="14dp">

            <ImageView
                android:id="@+id/imageCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/surface"
                app:srcCompat="@drawable/cover_placeholder"/>
        </FrameLayout>

        <!-- Título y artista -->
        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"/>

        <TextView
            android:id="@+id/textArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Selecciona una pista"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:gravity="center"/>

        <!-- Barra de progreso + tiempos -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textCurrent"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_dim"
                android:textSize="11sp"/>

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent"/>

            <TextView
                android:id="@+id/textTotal"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_dim"
                android:textSize="11sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Controles principales -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="5">

            <ImageButton
                android:id="@+id/btnShuffle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/btn_tint_selector"
                android:contentDescription="Aleatorio"/>

            <ImageButton
                android:id="@+id/btnPrev"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_skip_prev"
                android:tint="@color/text_primary"
                android:contentDescription="Anterior"/>

            <ImageButton
                android:id="@+id/btnPlay"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_play_button"
                android:padding="14dp"
                android:src="@drawable/ic_play"
                android:tint="@android:color/white"
                android:contentDescription="Play/Pausa"
                android:elevation="4dp"/>

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/text_primary"
                android:contentDescription="Siguiente"/>

            <ImageButton
                android:id="@+id/btnRepeat"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="10dp"
                android:src="@drawable/ic_repeat"
                android:tint="@color/btn_tint_selector"
                android:contentDescription="Repetir"/>
        </LinearLayout>

        <!-- Volumen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_volume"
                android:tint="@color/text_dim"
                android:contentDescription="Volumen"/>

            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:max="15"
                android:progress="10"
                android:progressTint="@color/text_muted"
                android:thumbTint="@color/text_muted"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Lista de reproducción ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:background="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LISTA DE REPRODUCCIÓN"
                android:textColor="@color/text_dim"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/divider"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPlaylist"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"/>
    </LinearLayout>

</LinearLayout>
